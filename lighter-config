#!/usr/bin/env bash
#
# lighter-agent-kit — credential configuration helper

set -euo pipefail

if [[ -z "${BASH_VERSION:-}" ]]; then
  printf 'Error: this helper requires bash.\n' >&2
  exit 1
fi

CREDENTIALS_DIR="${HOME}/.lighter/lighter-agent-kit"
CRED_FILE="${CREDENTIALS_DIR}/credentials"

# Colors
if [[ -t 1 ]] && [[ "${TERM:-dumb}" != "dumb" ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  BOLD='\033[1m'
  DIM='\033[2m'
  RESET='\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' BOLD='' DIM='' RESET=''
fi

info()    { printf "${BLUE}•${RESET} %s\n" "$*"; }
success() { printf "${GREEN}✓${RESET} %s\n" "$*"; }
warn()    { printf "${YELLOW}!${RESET} %s\n" "$*" >&2; }
error()   { printf "${RED}✗${RESET} %s\n" "$*" >&2; }

has_cmd() { command -v "$1" &>/dev/null; }

PYTHON_CMD=""
find_python() {
  for cmd in python3 python; do
    if has_cmd "$cmd"; then
      PYTHON_CMD="$cmd"
      return 0
    fi
  done
  return 1
}

# Prints "INDEX<TAB>LABEL" lines for each account, or nothing on failure.
fetch_accounts_by_l1() {
  local l1_address="$1" host="$2"
  local url="${host}/api/v1/accountsByL1Address?l1_address=${l1_address}"
  local raw=""

  if has_cmd curl; then
    raw=$(curl -fsSL --connect-timeout 10 "$url" 2>/dev/null) || true
  elif has_cmd wget; then
    raw=$(wget -qO- --timeout=10 "$url" 2>/dev/null) || true
  fi

  [[ -z "$raw" ]] && return 1

  echo "$raw" | "$PYTHON_CMD" -c "
import sys, json
try:
    data = json.loads(sys.stdin.read())
    for a in data.get('sub_accounts', []):
        label = 'Main Account' if a.get('account_type') == 0 else 'Sub-Account'
        print(str(a['index']) + '\t' + label)
except Exception:
    pass
"
}

write_credentials_file() {
  local api_key="$1" account_index="$2" api_key_index="$3" host="$4"

  mkdir -p "$(dirname "$CRED_FILE")"
  if [[ -e "$CRED_FILE" ]]; then
    chmod 600 "$CRED_FILE"
  else
    (umask 077 && : > "$CRED_FILE")
  fi

  cat > "$CRED_FILE" <<EOF
LIGHTER_API_PRIVATE_KEY=${api_key}
LIGHTER_ACCOUNT_INDEX=${account_index}
LIGHTER_API_KEY_INDEX=${api_key_index}
LIGHTER_HOST=${host}
EOF

  chmod 600 "$CRED_FILE"
}

# pick "prompt" "opt1" "opt2" ...  →  stdout = selected option
pick() {
  local prompt="$1"; shift
  local options=("$@")
  printf "${BOLD}%s${RESET}\n" "$prompt" >&2
  local i=1
  for opt in "${options[@]}"; do
    printf "  ${DIM}[%d]${RESET} %s\n" "$i" "$opt" >&2
    ((i++))
  done
  while true; do
    printf "  Choice [1-%d]: " "${#options[@]}" >&2
    local choice=""
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#options[@]} )); then
      echo "${options[$((choice - 1))]}"
      return 0
    fi
    warn "Enter a number between 1 and ${#options[@]}."
  done
}

main() {
  if ! find_python; then
    error "Python 3 is required for account lookup but was not found."
    exit 1
  fi

  if ! has_cmd curl && ! has_cmd wget; then
    error "curl or wget is required."
    exit 1
  fi

  printf "\n${BOLD}Configure Lighter credentials${RESET}\n\n"

  if [[ -f "$CRED_FILE" ]]; then
    warn "Existing credentials at $CRED_FILE will be overwritten."
    printf "  Continue? [Y/n]: "
    local reply=""
    read -r reply
    case "${reply:-y}" in
      [Nn]*) info "Cancelled."; exit 0 ;;
    esac
    echo ""
  fi

  # Network
  local network host
  network=$(pick "Which network?" \
    "Mainnet (mainnet.zklighter.elliot.ai)" \
    "Testnet (testnet.zklighter.elliot.ai)")
  case "$network" in
    Mainnet*) host="https://mainnet.zklighter.elliot.ai" ;;
    Testnet*) host="https://testnet.zklighter.elliot.ai" ;;
  esac
  echo ""

  # L1 address → account index lookup
  local account_index=""
  while [[ -z "$account_index" ]]; do
    printf "${BOLD}Ethereum L1 Address${RESET} (0x...): "
    local l1_address=""
    read -r l1_address
    l1_address="$(echo "$l1_address" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [[ -z "$l1_address" ]]; then
      error "Address required."
      continue
    fi

    info "Looking up account..."
    local accounts_raw=""
    accounts_raw=$(fetch_accounts_by_l1 "$l1_address" "$host") || accounts_raw=""

    if [[ -z "$accounts_raw" ]]; then
      warn "No accounts found for that address on this network."
      printf "  Try a different address? [Y/n]: "
      local retry=""
      read -r retry
      case "${retry:-y}" in [Nn]*) exit 0 ;; esac
      continue
    fi

    local indices=() labels=() options=()
    while IFS=$'\t' read -r idx lbl; do
      indices+=("$idx")
      labels+=("$lbl")
      options+=("${lbl} (index: ${idx})")
    done <<< "$accounts_raw"

    if (( ${#options[@]} == 1 )); then
      account_index="${indices[0]}"
      success "Account found: ${labels[0]} (index: ${account_index})"
    else
      echo ""
      local selected
      selected=$(pick "Select account:" "${options[@]}")
      for i in "${!options[@]}"; do
        if [[ "${options[$i]}" == "$selected" ]]; then
          account_index="${indices[$i]}"
          break
        fi
      done
    fi
  done
  echo ""

  # API key (hidden input)
  info "Get your API private key at: https://app.lighter.xyz/apikeys"
  info "If you chose a sub-account, switch to it before generating a key."
  echo ""
  printf "${BOLD}API Private Key${RESET} ${DIM}(input hidden)${RESET}: "
  local api_key=""
  read -rs api_key
  echo ""
  api_key="$(echo "$api_key" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/^["'"'"']//;s/["'"'"']$//')"
  if [[ -z "$api_key" ]]; then
    error "API key required."
    exit 1
  fi

  # API key index
  printf "${BOLD}API Key Index${RESET}: "
  local api_key_index=""
  read -r api_key_index
  api_key_index="$(echo "$api_key_index" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if [[ ! "$api_key_index" =~ ^[0-9]+$ ]] || (( 10#$api_key_index < 4 || 10#$api_key_index > 255 )); then
    error "Invalid API key index."
    exit 1
  fi

  echo ""
  write_credentials_file "$api_key" "$account_index" "$api_key_index" "$host"
  success "Credentials written to $CRED_FILE (mode 600)"
}

main "$@"
